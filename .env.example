# ============================================================
# 이 파일은 .env 템플릿입니다. Git에 커밋해도 안전합니다.
# 실제 값을 채워서 .env 파일로 복사해서 사용하세요.
#   cp .env.example .env
# ============================================================

# Gemini AI API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=여기에_Gemini_API_Key_입력

# Admin 초기 계정 비밀번호
ADMIN_PASSWORD=여기에_관리자_비밀번호_입력
